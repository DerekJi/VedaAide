# VedaAide 环境变量配置示例
# 
# 复制此文件为 .env，然后根据实际需求修改值
# DO NOT commit .env file to Git!

# ============================================
# Telegram Bot 配置
# ============================================
# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 接收每日提醒的 chat ID（不设则跳过主动推送）
# 获取方式：给 @userinfobot 发消息，复制 "Id" 字段
TELEGRAM_CHAT_ID=

# ============================================
# AI 模型配置
# ============================================
# DeepSeek API Key（从 platform.deepseek.com 获取）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 使用的模型（默认 deepseek-chat，性价比最高）
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# 存储配置
# ============================================
# SQLite 数据库文件路径（Bot 直连，无需 HTTP 服务）
# 本地开发默认值；生产环境由 fly.toml [env] 中的 DB_PATH 覆盖
DB_PATH=./data/vedaaide.db

# ============================================
# 系统配置
# ============================================
# 时区设置（影响每日提醒发送时间）
TZ=Asia/Shanghai

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO


# ============================================
# 可选：通知配置
# ============================================
# Slack Webhook URL（用于执行通知）
# 获取方法：https://api.slack.com/apps
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# 开发配置（localhost 用）
# ============================================
# DEBUG 模式
# DEBUG=true

# 快速启动（跳过某些初始化）
# FAST_START=false
