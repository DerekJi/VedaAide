# VedaAide 环境变量配置示例
# 
# 复制此文件为 .env，然后根据实际需求修改值
# DO NOT commit .env file to Git!

# ============================================
# Telegram Bot 配置
# ============================================
# 从 @BotFather 获取
TG_TOKEN=your_telegram_bot_token_here

# ============================================
# AI 模型配置
# ============================================
# Ollama 服务地址
OLLAMA_URL=http://ollama:11434

# 推荐模型（必须提前拉取）
# 首次启动后，进入 ollama 容器：
# docker exec -it ollama ollama pull qwen:7b-chat
# 或：docker exec -it ollama ollama pull llama3:8b
OLLAMA_MODEL=qwen:7b-chat

# ============================================
# 存储配置
# ============================================
# SQLite 数据库 Web API 地址
DB_URL=http://vedaaide-db:5000

# ChromaDB（向量数据库）地址（后期启用）
CHROMA_URL=http://chroma:8000

# ============================================
# 系统配置
# ============================================
# 时区设置
TZ=Asia/Shanghai

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# ============================================
# 可选：定时任务配置
# ============================================
# 每日简报推送时间（24小时制，HH:MM）
DAILY_BRIEFING_TIME=08:00

# 每周报告推送时间（WEEKLY: WEEKDAY HH:MM）
# WEEKDAY: 0-6（0=星期一，6=星期日）
WEEKLY_SUMMARY_TIME=6 20:00

# ============================================
# 可选：通知配置
# ============================================
# Slack Webhook URL（用于执行通知）
# 获取方法：https://api.slack.com/apps
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# 开发配置（localhost 用）
# ============================================
# DEBUG 模式
# DEBUG=true

# 快速启动（跳过某些初始化）
# FAST_START=false
